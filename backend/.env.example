## Backend helper scripts (.mjs)
## Copy to `backend/.env` (do NOT commit that file)
## Then run: `node <script>.mjs`

# PostgreSQL connection string to your Supabase database (pooler or direct).
# Example:
# SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# OpenAI API key used by setup scripts that store it in Supabase Vault
OPENAI_API_KEY=

