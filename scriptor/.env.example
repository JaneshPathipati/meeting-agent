# Scriptor Client Agent — Environment Variables
# Copy this to .env and fill in your credentials.
# These are embedded into the built binary via scripts/prebuild.js.

# Required — Supabase backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required — Azure AD (Microsoft OAuth for Teams integration)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id

# Optional — Azure client secret (for app-only Graph API access)
AZURE_CLIENT_SECRET=

# Optional — OpenAI API key (for GPT-4o meeting summaries; falls back to local model)
OPENAI_API_KEY=

# Optional — AssemblyAI API key (for transcription + speaker diarization)
ASSEMBLYAI_API_KEY=
